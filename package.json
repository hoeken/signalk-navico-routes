{
  "name": "signalk-navico-routes",
  "version": "1.0.0",
  "description": "Synchronize routes and waypoints between Navico MFDs (B&G, Simrad, etc.) and SignalK",
  "displayName": "Navico Route Sync",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "author": "Zach Hoeken <hoeken@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/hoeken/signalk-navico-routes"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-plugin-configurator",
    "signalk-category-navigation",
    "signalk",
    "navico",
    "b&g",
    "simrad",
    "lowrance",
    "routes",
    "waypoints",
    "usr"
  ],
  "engines": {
    "node": ">=20"
  },
  "signalk": {
    "appIcon": "logo.png",
    "displayName": "Navico Route Sync",
    "screenshots": [
      "./docs/screenshots/webapp.png",
      "./docs/screenshots/confirmation.png",
      "./docs/screenshots/config.png",
      "./docs/screenshots/export.png"
    ],
    "recommends": [
      "signalk-navico-embedder"
    ]
  },
  "files": [
    "dist",
    "docs",
    "public"
  ],
  "scripts": {
    "build": "tsc && npm run build:webapp && npm run build:configpanel",
    "generate:icons": "node scripts/generate-icons.mjs",
    "build:webapp": "esbuild webapp/src/app.tsx --bundle --minify --sourcemap --target=chrome69 --jsx=automatic --jsx-import-source=preact --outfile=public/app.js",
    "build:configpanel": "webpack",
    "typecheck:webapp": "tsc --noEmit -p webapp",
    "typecheck:configpanel": "tsc --noEmit -p configpanel",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test webapp/src configpanel",
    "format": "prettier --write src test webapp configpanel scripts docs *.md",
    "format:check": "prettier --check src test webapp configpanel",
    "ci": "npm run lint && npm run typecheck:webapp && npm run typecheck:configpanel && npm run test && npm run build",
    "prepare": "husky || true",
    "prepublishOnly": "npm run ci"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,css,html,md}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "png-to-ico": "^3.0.2",
    "preact": "^10.29.7",
    "prettier": "^3.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.35.3",
    "ts-loader": "^9.5.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0",
    "webpack": "^5.105.0",
    "webpack-cli": "^7.0.0"
  }
}
