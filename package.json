{
  "name": "signalk-navico-routes",
  "version": "0.1.0",
  "description": "Synchronize routes and waypoints between Navico MFDs (B&G Zeus, Simrad NSS, Lowrance HDS) and SignalK via GoFree USR file transfer",
  "displayName": "Navico Route Sync",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "author": "Zach Hoeken <hoeken@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/hoeken/signalk-navico-routes"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-navigation",
    "signalk",
    "navico",
    "b&g",
    "simrad",
    "lowrance",
    "routes",
    "waypoints",
    "usr"
  ],
  "engines": {
    "node": ">=20"
  },
  "signalk": {
    "appIcon": "logo.png",
    "displayName": "Navico Route Sync",
    "screenshots": [],
    "recommends": [
      "signalk-navico-embedder"
    ]
  },
  "files": [
    "dist",
    "docs",
    "public"
  ],
  "scripts": {
    "build": "tsc && npm run build:webapp",
    "generate:icons": "node scripts/generate-icons.mjs",
    "build:webapp": "esbuild webapp/src/app.tsx --bundle --minify --sourcemap --target=chrome69 --jsx=automatic --jsx-import-source=preact --outfile=public/app.js",
    "typecheck:webapp": "tsc --noEmit -p webapp",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test webapp/src",
    "format": "prettier --write src test webapp scripts docs *.md",
    "format:check": "prettier --check src test webapp",
    "ci": "npm run lint && npm run typecheck:webapp && npm run test && npm run build",
    "prepublishOnly": "npm run ci"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "png-to-ico": "^3.0.2",
    "preact": "^10.29.7",
    "prettier": "^3.3.0",
    "sharp": "^0.35.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}